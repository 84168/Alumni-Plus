                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <!-- SESSION FORM -->
                            <form id="sessionForm" action="/schedule-session" method="POST">
                                <div class="form-grid">
                                    <!-- Session Title -->
                                    <div class="form-group form-group-full">
                                        <label for="sessionTitle">Session Title <span class="required">*</span></label>
                                        <input type="text" id="sessionTitle" name="sessionTitle" class="form-control"
                                            placeholder="e.g., Career Guidance in Software Development" required>
                                    </div>

                                    <!-- Mentor/Alumni -->
                                    <div class="form-group">
                                        <label for="AlumniDropdown">Mentor/Alumni <span
                                                class="required">*</span></label>
                                        <select id="AlumniDropdown" class="form-control"
                                            onchange="syncAlumniName(this)">
                                            <option value="">-- Select Mentor --</option>
                                            <% interestedAlumni.forEach((alumni)=> { %>
                                                <option value="<%= alumni.ID %>" data-name="<%= alumni.Full_Name %>">
                                                    <%= alumni.Full_Name %> {<%=alumni.ID%>}
                                                </option>
                                                <% }) %>
