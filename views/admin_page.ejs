                                                                    <div class="detail-icon-small">⏱️</div>
                                                                    <div class="detail-label-small">Duration</div>
                                                                    <div class="detail-value-small"
                                                                        id="accduration-<%=schedule.Session_ID%>">
                                                                        <%= schedule.Duration %>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="detail-item-card">
                                                                <div class="detail-icon-small">
                                                                    <%= schedule.Mode==='online' ? '💻' : '📍' %>
                                                                </div>
                                                                <div class="detail-label-small">Mode</div>
                                                                <div class="detail-value-small"
                                                                    id="accmode-<%=schedule.Session_ID%>">
                                                                    <%= schedule.Mode.charAt(0).toUpperCase() +
                                                                        schedule.Mode.slice(1) %>
                                                                        <span
                                                                            class="card-mode-badge mode-<%= schedule.Mode %>-badge">
                                                                            <%= schedule.Mode==='Online' ?
                                                                                schedule.platform : schedule.location %>
                                                                        </span>
                                                                </div>
                                                            </div>

                                                            <div class="card-actions">
                                                                <button class="card-btn card-btn-primary"
                                                                    id="accschedule-<%=schedule.Session_ID%>"
                                                                    onclick="ScheduleSession('<%= schedule.Session_ID %>')">Schedule
                                                                    Session</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div class="empty-state">
                                                                <div class="empty-state-icon">✅</div>
                                                                <h3 class="empty-state-title">No Accepted Sessions</h3>
                                                                <p class="empty-state-message">None of Alumni accept any
                                                                    mentorship sessions request yet.</p>
                                                            </div>
                                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Batch Convert Section -->
                    <div id="batch-convert-section" class="hidden">
                        <div class="content-section">
                            <div class="section-header">
                                <h3>Batch to Alumni Converter</h3>
                            </div>
                            <div style="padding: 32px;">

                                <div
                                    style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
                                    <label style="font-size: 14px; color: #718096; white-space: nowrap;">Batch
                                        Year</label>
                                    <input type="number" id="batchInput" placeholder="e.g. 2025" min="2000" max="2099"
                                        style="width: 160px; padding: 10px 14px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: 15px; outline: none;" />
                                    <button onclick="fetchStudents()"
                                        style="padding: 10px 22px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer;">
                                        Search Students
                                    </button>
                                </div>

                                <div id="batchStatusMsg"
                                    style="display:none; margin-bottom: 16px; padding: 12px 16px; border-radius: 10px; font-size: 14px; font-weight: 500;">
                                </div>

                                <div id="studentPanel" style="display:none;">

                                    <div
                                        style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; flex-wrap: wrap; gap: 8px;">
                                        <span id="batchLabel"
                                            style="font-size: 15px; font-weight: 700; color: #2d3748;"></span>
                                        <label
                                            style="font-size: 13px; color: #718096; display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: 600;">
                                            <input type="checkbox" id="batchSelectAll" onchange="toggleSelectAll(this)"
                                                style="width: 16px; height: 16px; cursor: pointer;" />
                                            Select All
                                        </label>
                                    </div>

                                    <div id="studentList"
                                        style="max-height: 340px; overflow-y: auto; border: 1.5px solid #e8ebff; border-radius: 14px; background: #fff;">
                                    </div>

                                    <div
                                        style="display: flex; align-items: center; justify-content: space-between; margin-top: 20px; flex-wrap: wrap; gap: 12px;">
                                        <span id="batchSelectedCount"
                                            style="font-size: 13px; color: #718096; font-weight: 600;">0 selected</span>
                                        <button id="convertBtn" onclick="convertToAlumni()" disabled
                                            style="padding: 11px 28px; font-size: 14px; font-weight: 700; background: linear-gradient(135deg, #48bb78 0%, #38a169 100%); color: white; border: none; border-radius: 10px; opacity: 0.5; cursor: not-allowed; transition: all 0.2s;">
                                            🎓 Change to Alumni
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    <!-- Pending Contribution  -->
                     <!-- Pending Contribution -->
<div id="pending-contribution-section" class="hidden">
    <div class="content-section">
        <div class="section-header">
            <h3>Pending To Verify Contributions</h3>
        </div>
        <div style="padding: 32px;">
            <% if (contributions && contributions.length > 0) { %>
                <table class="table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Alumni ID</th>
                            <th>Amount (₹)</th>
                            <th>Anonymous</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% contributions.forEach(function(c) { %>
                            <tr>
                                <td><%= c.id %></td>
                                <td><%= c.Is_Anonymous === 1 ? 'Anonymous' : c.Alumni_ID %></td>
                                <td>₹<%= parseFloat(c.Amount).toFixed(2) %></td>
                                <td><%= c.Is_Anonymous === 1 ? 'Yes' : 'No' %></td>
                                <td><%= new Date(c.Created_At).toLocaleString('en-IN') %></td>
                                <td>
                                    <form action="/verify_contribution" method="POST" style="display:inline;">
                                        <input type="hidden" name="contribution_id" value="<%= c.id %>">
                                        <button type="submit" class="btn btn-success btn-sm">✓ Approve</button>
                                    </form>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p style="text-align:center; color: #888;">No pending contributions found.</p>
            <% } %>
        </div>
    </div>
</div>
            

            

        </div>
    </div>
</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Announcement Modal -->
    <div id="announcement-modal" class="modal hidden" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Create Announcement</h3>
                <button class="close" onclick="closeModal('announcement-modal')">&times;</button>
            </div>
            <form id="announcement-form" action="/announcement" method="post" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="Title" class="form-control" placeholder="Announcement title"
                        required>
                </div>

                <div class="form-group">
                    <label for="description">Content</label>
                    <textarea id="description" name="Description" class="form-control"
                        placeholder="Write your announcement..." required></textarea>
                </div>

                <div class="form-group">
                    <label for="important_links">Important Links</label>
                    <input type="text" id="important_links" name="Important_Links" class="form-control"
                        placeholder="Add URLs separated by commas">
                </div>

                <div class="form-group">
                    <label for="posted_on">Posted On</label>
                    <input type="date" id="posted_on" name="Posted_On" class="form-control">
                </div>

                <div class="form-group">
                    <label for="attachment">Attach PDF or Image</label>
                    <input type="file" id="attachment" name="Attachment_Url" class="form-control" accept=".pdf,image/*">
                </div>

                <div class="form-group">
                    <label for="visibility">Visibility</label>
                    <select id="visibility" name="Visibility" class="form-control">
                        <option value="All Users" selected>All Users</option>
                        <option value="Alumni">Alumni Only</option>
                        <option value="Student">Students Only</option>
                        <option value="Faculty">Faculty Only</option>
                    </select>
                </div>

                <div class="btn-group">
                    <button type="button" class="btn btn-danger"
                        onclick="closeModal('announcement-modal')">Cancel</button>
                    <button type="submit" class="btn btn-primary">Post Announcement</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const announcement = document.getElementById("announcement-modal");
        const form = document.getElementById("sessionForm");
        const Schedule_Form = document.getElementById("Schedule_Form");
        const table = document.getElementById("table");
        const Cancel_Form = document.getElementById("Cancel_Form");

        form.style.display = "none";
        Cancel_Form.style.display = "none";
        announcement.style.display = "none";

        Schedule_Form.addEventListener('click', () => {
            Schedule_Form.style.display = "none";
            form.style.display = "block";
            table.style.display = "none";
            Cancel_Form.style.display = "block";
        })

        Cancel_Form.addEventListener('click', () => {
            Schedule_Form.style.display = "block";
            form.style.display = "none";
            table.style.display = "block";
            Cancel_Form.style.display = "none";
        })

        function openUserCard(id) {
            document.getElementById(id).style.display = "flex";
        }

        function closeUserCard(id) {
            document.getElementById(id).style.display = "none";
        }

        function openRequestCard(id) {
            document.getElementById(id).style.display = "flex";
        }

        function closeRequestCard(id) {
            document.getElementById(id).style.display = "none";
        }

        // Close modal when clicking outside
        window.onclick = function (event) {
            const modals = document.querySelectorAll(".modal");
            modals.forEach(modal => {
                if (event.target === modal) {
                    modal.style.display = "none";
                }
            });
        }

        function showSection(sectionName) {
            // Hide all sections
            const sections = ['overview', 'user-verification', 'student-needs', 'mentorship', 'announcements', 'sessions', 'batch-convert','pending-contribution'];
            sections.forEach(section => {
                document.getElementById(section + '-section').classList.add('hidden');
            });
            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.remove('active');
            });
            document.getElementById(sectionName + '-section').classList.remove('hidden');
            event.target.classList.add('active');
            const titles = {
                'overview': 'Dashboard Overview',
                'user-verification': 'User Verification',
                'student-needs': 'Student Needs',
                'mentorship': 'Mentorship Requests',
                'announcements': 'Announcements',
                'sessions': 'Mentorship Sessions',
                'batch-convert': 'Batch to Alumni Converter',
                'pending-contribution':'Pending To Verify Contribution'
            };
            document.getElementById('page-title').textContent = titles[sectionName];
        }

        // function showModal(modalType) {
        //     document.getElementById(modalType + '-modal').style.display = 'flex';
        // }

        // function closeModal(modalId) {
        //     document.getElementById(modalId).style.display = 'none';
        // }
        function showModal(modalType) {
            const modal = document.getElementById(modalType + '-modal');
            modal.classList.remove('hidden');
            modal.style.display = 'flex';
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            modal.classList.add('hidden');
            modal.style.display = 'none';
        }

        function toggleVenue() {
            const onlineRadio = document.getElementById("online");
            const inPersonRadio = document.getElementById("inPerson");
            const meetingLinkGroup = document.getElementById("meetingLinkGroup");
            const physicalVenue = document.getElementById("physicalVenue");

            if (onlineRadio.checked) {
                meetingLinkGroup.style.display = "block";
                physicalVenue.style.display = "none";
            } else if (inPersonRadio.checked) {
                meetingLinkGroup.style.display = "none";
                physicalVenue.style.display = "block";
            }
        }

        function editAnnounceCard(index, title, description, postedOn, visibility, links) {
            // Title
            document.getElementById(`title-${index}`).innerHTML = `
                <input type="text" id="edit-title-${index}" class="form-control" value="${title}" />
            `;

            // Description
            document.getElementById(`desc-${index}`).innerHTML = `
                <textarea id="edit-desc-${index}" class="form-control">${description}</textarea>
            `;

            // Meta (Posted On + Visibility)
            document.getElementById(`meta-${index}`).innerHTML = `
                📅 Posted on <input type="date" id="edit-date-${index}" class="form-control" style="display:inline-block; width:auto;" value="${formatDate(postedOn)}" /> • 
                👁️ Visible to: 
                <select id="edit-visibility-${index}" class="form-control" style="display:inline-block; width:auto;">
                    <option ${visibility === 'All Users' ? 'selected' : ''}>All Users</option>
                    <option ${visibility === 'Alumni' ? 'selected' : ''}>Alumni</option>
                    <option ${visibility === 'Student' ? 'selected' : ''}>Student</option>
                    <option ${visibility === 'Faculty' ? 'selected' : ''}>Faculty</option>
                </select>
            `;

            // Important Links
            document.getElementById(`links-${index}`).innerHTML = `
                🔗 Important Links:
                <input type="text" id="edit-links-${index}" class="form-control" value="${links}" placeholder="Comma-separated URLs" />
            `;

            // Replace buttons with Save
            document.getElementById(`actions-${index}`).innerHTML = `
                <button class="btn btn-success btn-sm" onclick="saveAnnouncement(${index})">Save</button>
                <button class="btn btn-danger btn-sm" onclick="cancelEdit(${index})">Cancel</button>
            `;
        }

        // Helper to format date to yyyy-mm-dd
        function formatDate(dateStr) {
            const date = new Date(dateStr);
            const yyyy = date.getFullYear();
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }

        // SEND MENTORSHIP REQUEST TO ALUMNI 
        function syncAlumniName(selectElement) {
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            document.getElementById('AlumniID').value = selectedOption.value;
            document.getElementById('AlumniName').value = selectedOption.getAttribute('data-name');
        }

        // CREATING A FORM THROUGH JS TO UPDATE IN TABLE
        function saveAnnouncement(index) {
            const form = document.createElement("form");
            form.method = "POST";
            form.action = `/announcement/update/${index}`;
            form.enctype = "multipart/form-data";

            const fields = {
                Title: document.getElementById(`edit-title-${index}`).value,
                Description: document.getElementById(`edit-desc-${index}`).value,
                Posted_On: document.getElementById(`edit-date-${index}`).value,
                Visibility: document.getElementById(`edit-visibility-${index}`).value,
                Important_Links: document.getElementById(`edit-links-${index}`).value
            };

            for (const key in fields) {
                const input = document.createElement("input");
                input.type = "hidden";
                input.name = key;
                input.value = fields[key];
                form.appendChild(input);
            }

            // File input
            const fileInput = document.getElementById(`edit-attachment-${index}`);
            if (fileInput && fileInput.files.length > 0) {
                form.appendChild(fileInput.cloneNode(true));
            }
            document.body.appendChild(form);
            form.submit();
        }

        // Optional cancel function
        function cancelEdit(index) {
            location.reload();
        }

        // DELETE ANNOUNCEMENTS
        function deleteAnnounceCard(id) {
            if (confirm('Are you sure you want to delete this announcement?')) {
                const form = document.createElement("form");
                form.method = "POST";
                form.action = `/announcement/delete/${id}`;
                document.body.appendChild(form);
                form.submit();
            }
        }

        // FOR MENTORSHIP SESSIONS  
        function deleteSession(id) {
            if (confirm('Are you sure you want to delete this session?')) {
                const form = document.createElement("form");
                form.method = "POST";
                form.action = `/schedule-session/delete/${id}`;
                document.body.appendChild(form);
                form.submit();
            }
        }

        // TO SCHEDULE SESSION AFTER ALUMNI ACCEPTED THE REQUEST 
        function ScheduleSession(Session_ID) {
            window.location.href = `/scheduleAlumniMentorReq/${Session_ID}`;
        }

        // TO ASSIGN FACULTY TO SUPPORT REQUEST 
        function syncMentorName(index) {
            const dropdown = document.getElementById(`mentorDropdown-${index}`);
            const selectedOption = dropdown.options[dropdown.selectedIndex];
            const name = selectedOption.getAttribute('data-name');
            const id = selectedOption.value;

            document.getElementById(`MentorID-${index}`).value = id;
            document.getElementById(`MentorName-${index}`).value = name;
        }

        function setAction(form) {
            // const action = form.action.value;

            // if (action === 'approve') {

            //     const index = form.closest('tr').rowIndex - 1;
            //     const mentorId = document.getElementById(`MentorID-${index}`);

            //     if (mentorId && !mentorId.value) {
            //         alert("Please assign a mentor before approving.");
            //         return false;
            //     }
            // }

            return true;
        }
        // ===================== BATCH TO ALUMNI CONVERTER =====================
        let batchStudents = [];
        let batchSelected = new Set();

        function showBatchStatus(msg, type) {
            const el = document.getElementById('batchStatusMsg');
            el.style.display = 'block';
            el.textContent = msg;
            if (type === 'success') {
                el.style.background = '#f0fff4';
                el.style.color = '#276749';
                el.style.border = '1.5px solid #9ae6b4';
            } else if (type === 'error') {
                el.style.background = '#fff5f5';
                el.style.color = '#c53030';
                el.style.border = '1.5px solid #feb2b2';
            } else {
                el.style.background = '#ebf8ff';
                el.style.color = '#2b6cb0';
                el.style.border = '1.5px solid #90cdf4';
            }
        }

        async function fetchStudents() {
            const batch = document.getElementById('batchInput').value.trim();
            if (!batch || isNaN(batch) || batch.length !== 4) {
                showBatchStatus('Please enter a valid 4-digit batch year.', 'error');
                return;
            }

            document.getElementById('batchStatusMsg').style.display = 'none';
            document.getElementById('studentPanel').style.display = 'none';
            batchStudents = [];
            batchSelected.clear();
            document.getElementById('batchSelectAll').checked = false;

            try {
                const res = await fetch(`/admin/students-by-batch/${batch}`);
                batchStudents = await res.json();

                if (!Array.isArray(batchStudents) || batchStudents.length === 0) {
                    showBatchStatus(`No unconverted students found for batch ${batch}.`, 'error');
                    return;
                }

                document.getElementById('batchLabel').textContent =
                    `Batch ${batch} — ${batchStudents.length} student${batchStudents.length > 1 ? 's' : ''} found`;
                renderStudentList();
                document.getElementById('studentPanel').style.display = 'block';
                updateConvertBtn();
            } catch (e) {
                showBatchStatus('Network error. Could not fetch students.', 'error');
            }
        }

        function renderStudentList() {
            const list = document.getElementById('studentList');
            list.innerHTML = batchStudents.map((s, i) => `
        <label style="display: flex; align-items: center; gap: 14px; padding: 13px 18px; cursor: pointer;
            border-bottom: 1px solid #f0f0f0; transition: background 0.15s;"
            onmouseover="this.style.background='#f8f9ff'"
            onmouseout="this.style.background='transparent'">
            <input type="checkbox" data-idx="${i}" onchange="toggleBatchItem(this)"
                style="width: 16px; height: 16px; cursor: pointer; accent-color: #667eea;" />
            <div>
                <div style="font-size: 14px; font-weight: 700; color: #2d3748;">${s.Full_Name}</div>
                <div style="font-size: 12px; color: #a0aec0; margin-top: 2px;">
                    ${s.Enrollment_No} &nbsp;·&nbsp; ${s.Email_ID || 'No email'}
                </div>
            </div>
        </label>
    `).join('');
        }

        function toggleBatchItem(cb) {
            const i = parseInt(cb.dataset.idx);
            if (cb.checked) batchSelected.add(i); else batchSelected.delete(i);
            document.getElementById('batchSelectAll').checked = batchSelected.size === batchStudents.length;
            updateConvertBtn();
        }

        function toggleSelectAll(cb) {
            batchSelected.clear();
            document.querySelectorAll('#studentList input[type=checkbox]').forEach((el, i) => {
                el.checked = cb.checked;
                if (cb.checked) batchSelected.add(i);
            });
            updateConvertBtn();
        }

        function updateConvertBtn() {
            const btn = document.getElementById('convertBtn');
            const n = batchSelected.size;
            document.getElementById('batchSelectedCount').textContent = `${n} student${n !== 1 ? 's' : ''} selected`;
            btn.disabled = n === 0;
            btn.style.opacity = n === 0 ? '0.5' : '1';
            btn.style.cursor = n === 0 ? 'not-allowed' : 'pointer';
        }

        async function convertToAlumni() {
            const toConvert = [...batchSelected].map(i => batchStudents[i]);
            if (toConvert.length === 0) return;

            const btn = document.getElementById('convertBtn');
            btn.textContent = 'Converting...';
            btn.disabled = true;
            btn.style.opacity = '0.6';

            try {
                const res = await fetch('/admin/batch-convert-to-alumni', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ students: toConvert })
                });
                const data = await res.json();

                if (res.ok && data.success) {
                    showBatchStatus(
                        `Successfully converted ${toConvert.length} student${toConvert.length > 1 ? 's' : ''} to alumni!`,
                        'success'
                    );
                    // Remove converted students from list
                    batchStudents = batchStudents.filter((_, i) => !batchSelected.has(i));
                    batchSelected.clear();
                    document.getElementById('batchSelectAll').checked = false;
                    renderStudentList();

                    const batch = document.getElementById('batchInput').value.trim();
                    document.getElementById('batchLabel').textContent = batchStudents.length === 0
                        ? `All students in batch ${batch} have been converted!`
                        : `Batch ${batch} — ${batchStudents.length} student${batchStudents.length > 1 ? 's' : ''} remaining`;
                } else {
                    showBatchStatus('Error: ' + (data.message || 'Conversion failed. Please try again.'), 'error');
                }
            } catch (e) {
                showBatchStatus('Network error. Could not reach server.', 'error');
            }

            btn.textContent = '🎓 Change to Alumni';
            btn.disabled = false;
            updateConvertBtn();
        }
    </script>
</body>

</html>