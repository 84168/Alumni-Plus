                                    <label for="venue">Venue/Location</label>
                                    <input type="text" id="venue" name="venue" class="form-control"
                                        placeholder="Don't Fill if Mode is Online">
                                </div>

                                <div class="btn-group">
                                    <button type="submit" class="btn btn-primary">📅 Schedule Session</button>
                                </div>
                            </form>
                        </div>
                    </div>

