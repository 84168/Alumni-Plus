<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AlumniPlus | SGSITS CSE Department, Indore</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg: #f5f4f0;
            --surface: #ffffff;
            --primary: #1a1a2e;
            --accent: #e84545;
            --accent2: #903749;
            --text: #1a1a2e;
            --muted: #6b6b80;
            --border: #e2e0da;
            --radius: 14px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: var(--primary);
            padding: 28px 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 20px rgba(0,0,0,0.3);
        }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.08);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.15);
            padding: 8px 18px;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.2s;
        }
        .back-btn:hover { background: rgba(255,255,255,0.15); }

        .header-title {
            font-family: 'DM Serif Display', serif;
            font-size: 22px;
            color: #fff;
        }

        .header-badge {
            background: var(--accent);
            color: #fff;
            font-size: 12px;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
        }

        /* Hero */
        .hero {
            background: var(--primary);
            padding: 60px 48px 80px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(47, 151, 255, 0.607) 0%, transparent 70%);
            top: -200px; left: 50%;
            transform: translateX(-50%);
            pointer-events: none;
        }

        .hero h1 {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(32px, 5vw, 56px);
            color: #fff;
            line-height: 1.15;
            margin-bottom: 12px;
            position: relative;
        }

        .hero h1 span { color: var(--accent); }

        .hero p {
            color: rgba(255,255,255,0.55);
            font-size: 16px;
            font-weight: 300;
            position: relative;
        }

        /* Search */
        .search-section {
            max-width: 680px;
            margin: -32px auto 0;
            padding: 0 24px;
            position: relative;
            z-index: 10;
        }

        .search-card {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: 0 8px 40px rgba(0,0,0,0.12);
            padding: 24px;
        }

        .search-card form {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .search-input-wrap {
            position: relative;
            flex: 2;
        }

        .search-input-wrap svg {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        .search-card input {
            width: 100%;
            padding: 11px 14px 11px 40px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            color: var(--text);
            background: var(--bg);
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .search-card input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(232,69,69,0.1);
        }

        .batch-input-wrap {
            position: relative;
            flex: 1;
        }

        .batch-input-wrap svg {
            position: absolute;
            left: 12px; top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        #batchFilter { padding-left: 36px !important; min-width: 120px; }

        .search-btn {
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 11px 22px;
            font-size: 14px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: background 0.2s, transform 0.15s;
            white-space: nowrap;
        }
        .search-btn:hover { background: var(--accent2); transform: translateY(-1px); }

        /* Section Header */
        .section-header {
            max-width: 1280px;
            margin: 56px auto 24px;
            padding: 0 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .section-title {
            font-family: 'DM Serif Display', serif;
            font-size: 28px;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-title::before {
            content: '';
            display: block;
            width: 4px; height: 28px;
            background: var(--accent);
            border-radius: 2px;
        }

        .result-count {
            font-size: 14px;
            color: var(--muted);
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 6px 14px;
            border-radius: 20px;
        }

        /* Grid */
        .alumni-grid {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 48px 60px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
            gap: 20px;
        }

        /* Card */
        .alumni-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px 18px 20px;
            text-align: center;
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
            display: none;
        }

        .alumni-card.active {
            display: block;
            animation: fadeCard 0.3s ease-out;
        }

        @keyframes fadeCard {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .alumni-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.09);
            border-color: rgba(232,69,69,0.3);
        }

        .alumni-avatar {
            width: 72px; height: 72px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--border);
            margin-bottom: 14px;
            transition: border-color 0.2s;
        }

        .alumni-card:hover .alumni-avatar { border-color: var(--accent); }

        .alumni-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 4px;
            line-height: 1.3;
        }

        .alumni-batch {
            display: inline-block;
            font-size: 12px;
            font-weight: 500;
            color: var(--accent);
            background: rgba(232,69,69,0.08);
            padding: 2px 10px;
            border-radius: 20px;
            margin-bottom: 14px;
        }

        .alumni-links {
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

        .alumni-link {
            font-size: 12.5px;
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            transition: color 0.2s;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .alumni-link:hover { color: var(--accent); }

        .divider {
            height: 1px;
            background: var(--border);
            margin: 10px 0;
        }

        /* Empty State */
        .empty-state {
            grid-column: 1/-1;
            text-align: center;
            padding: 80px 20px;
            color: var(--muted);
        }
        .empty-state svg { margin-bottom: 16px; opacity: 0.3; }
        .empty-state p { font-size: 16px; }

        /* Pagination */
        .pagination-wrap {
            max-width: 1280px;
            margin: 0 auto 60px;
            padding: 0 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .page-btn {
            min-width: 38px; height: 38px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 9px;
            border: 1.5px solid var(--border);
            background: var(--surface);
            color: var(--text);
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.15s;
            padding: 0 10px;
        }

        .page-btn:hover:not(:disabled) {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(232,69,69,0.05);
        }

        .page-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            font-weight: 600;
        }

        .page-btn:disabled { opacity: 0.35; cursor: not-allowed; }

        .page-dots {
            color: var(--muted);
            font-size: 14px;
            padding: 0 4px;
            line-height: 38px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header { padding: 20px 24px; }
            .hero { padding: 40px 24px 60px; }
            .search-card form { flex-wrap: wrap; }
            .search-input-wrap, .batch-input-wrap { flex: 1 1 100%; }
            .section-header { padding: 0 24px; flex-direction: column; align-items: flex-start; gap: 10px; }
            .alumni-grid { padding: 0 24px 40px; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
            .pagination-wrap { padding: 0 24px; }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <!-- <header class="header">
        <button class="back-btn" onclick="history.back()">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Back
        </button>
    </header> -->

    <!-- Hero -->
    <section class="hero">
        <button class="back-btn" onclick="history.back()">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Back
        </button>
        <h1>Explore Our<br><span>Alumni Network</span></h1>
        <p>Connect with graduates who've gone on to do great things.</p>
    </section>

    <!-- Search -->
    <div class="search-section">
        <div class="search-card">
            <form action="/alumni_search" method="post">
                <div class="search-input-wrap">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                    <input type="text" name="Name" id="searchName" placeholder="Search by full name...">
                </div>
                <div class="batch-input-wrap">
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                    <input type="text" name="Batch" id="batchFilter" placeholder="Batch year...">
                </div>
                <button type="submit" class="search-btn">Search</button>
            </form>
        </div>
    </div>

    <!-- Section Header -->
    <div class="section-header">
        <h2 class="section-title">CSE Alumni</h2>
        <span class="result-count" id="resultCount"></span>
    </div>

    <!-- Grid -->
    <div class="alumni-grid" id="alumniGrid">
        <% if(rows.length > 0) { %>
            <% rows.map((alumni) => { %>
                <div class="alumni-card">
                    <img src="https://static.vecteezy.com/system/resources/previews/019/896/008/non_2x/male-user-avatar-icon-in-flat-design-style-person-signs-illustration-png.png"
                         alt="Alumni Photo" class="alumni-avatar">
                    <div class="alumni-name"><%= alumni.Full_Name %></div>
                    <span class="alumni-batch">Batch <%= alumni.Batch %></span>
                    <div class="divider"></div>
                    <div class="alumni-links">
                        <a href="mailto:<%= alumni.Email_ID %>" class="alumni-link">
                            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 7L2 7"/></svg>
                            <%= alumni.Email_ID %>
                        </a>
                        <a href="https://linkedin.com" target="_blank" class="alumni-link">
                            <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                            LinkedIn Profile
                        </a>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <svg width="56" height="56" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <p>No alumni found matching your search.</p>
            </div>
        <% } %>
    </div>

    <!-- Pagination -->
    <div class="pagination-wrap" id="paginationWrap"></div>

    <script>
        const CARDS_PER_PAGE = 15; // change this number to show more/less per page

        const cards = Array.from(document.querySelectorAll('.alumni-card'));
        const total = cards.length;
        const totalPages = Math.ceil(total / CARDS_PER_PAGE);
        let currentPage = 1;

        const resultCount = document.getElementById('resultCount');
        const paginationWrap = document.getElementById('paginationWrap');

        if (total > 0) resultCount.textContent = total + ' alumni found';

        function showPage(page) {
            currentPage = page;
            const start = (page - 1) * CARDS_PER_PAGE;
            const end = start + CARDS_PER_PAGE;
            cards.forEach((card, i) => {
                card.classList.remove('active');
                if (i >= start && i < end) card.classList.add('active');
            });
            renderPagination();
            window.scrollTo({ top: document.getElementById('alumniGrid').offsetTop - 80, behavior: 'smooth' });
        }

        function renderPagination() {
            if (totalPages <= 1) { paginationWrap.innerHTML = ''; return; }
            let html = '';

            html += `<button class="page-btn" onclick="showPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
                     </button>`;

            getPageNumbers(currentPage, totalPages).forEach(p => {
                if (p === '...') {
                    html += `<span class="page-dots">…</span>`;
                } else {
                    html += `<button class="page-btn ${p === currentPage ? 'active' : ''}" onclick="showPage(${p})">${p}</button>`;
                }
            });

            html += `<button class="page-btn" onclick="showPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
                     </button>`;

            paginationWrap.innerHTML = html;
        }

        function getPageNumbers(current, total) {
            if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
            if (current <= 4) return [1, 2, 3, 4, 5, '...', total];
            if (current >= total - 3) return [1, '...', total-4, total-3, total-2, total-1, total];
            return [1, '...', current - 1, current, current + 1, '...', total];
        }

        showPage(1);
    </script>
</body>
</html>