                  razorpay_payment_id: response.razorpay_payment_id,
                  razorpay_signature: response.razorpay_signature
                })
              });

              const verifyData = await verifyResponse.json();

              if (verifyData.success) {
                statusDiv.innerHTML = `
                  <div style="background: #c6f6d5; color: #276749; padding: 15px; border-radius: 8px;">
                    <h3 style="margin: 0 0 10px 0;">✅ Payment Successful!</h3>
                    <p style="margin: 0; font-size: 14px;">Payment ID: ${response.razorpay_payment_id}</p>
                    <p style="margin: 5px 0 0 0; font-size: 14px;">Thank you for your contribution!</p>
                  </div>
                `;
                statusDiv.style.display = 'block';
                amountInput.value = '500';
                payButton.innerHTML = '💳 Contribute Again';
              } 
            } catch (error) {
              console.error('Verification error:', error);
              statusDiv.innerHTML = `
                <div style="background: #fed7d7; color: #c53030; padding: 15px; border-radius: 8px;">
                  <h3 style="margin: 0 0 10px 0;">⚠ Verification Error</h3>
                  <p style="margin: 0; font-size: 14px;">${error.message}</p>
                </div>
              `;
              statusDiv.style.display = 'block';
            }
            
            payButton.disabled = false;
            payButton.innerHTML = '💳 Contribute Now';
          },
          prefill: {
