    <!-- Endowment -->
    <section id="endowment">
        <div class="container">
            <div class="announcements-container">
                <div class="page-header">
                    <h1>📢 Endowment</h1>

                </div>
                <% if(authUser) {%>

                    <%if(authUser.Role=='alumni' ){%>
                        <!-- <p>Support future excellence-learn how contributions shape scholarships, research and innovations </p>-->

                        <div class="no-content">

                            <h2 style="text-align: center; color: #2d3748; margin-bottom: 20px; font-size: 28px;">
