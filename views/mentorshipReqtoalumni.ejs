<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mentorship Requests</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Lato:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #f0ede8;
            --surface:   #faf9f7;
            --card:      #ffffff;
            --border:    #e3dfd8;
            --text:      #1c1c1c;
            --muted:     #7a7570;
            --accent:    #2c4a3e;
            --accent-lt: #e8efed;
            --gold:      #b5913a;
            --gold-lt:   #faf5ea;
            --danger:    #7a3030;
            --danger-lt: #f5eded;
            --success:   #2c4a3e;
            --success-lt:#e8efed;
            --warn:      #7a5c2a;
            --warn-lt:   #faf3e8;
            --radius:    16px;
            --shadow:    0 2px 20px rgba(0,0,0,0.07);
            --shadow-lg: 0 8px 40px rgba(0,0,0,0.10);
        }

        body {
            font-family: 'Lato', sans-serif;
            background-color: var(--bg);
            background-image:
                radial-gradient(ellipse at 20% 10%, rgba(44,74,62,0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 90%, rgba(181,145,58,0.05) 0%, transparent 50%);
            min-height: 100vh;
            color: var(--text);
            padding: 48px 24px 80px;
        }

        /* ── Page Header ── */
        .page-header {
            max-width: 760px;
            margin: 0 auto 52px;
            text-align: center;
        }

        .page-eyebrow {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 12px;
        }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(28px, 4vw, 40px);
            font-weight: 600;
            color: var(--text);
            line-height: 1.2;
            margin-bottom: 12px;
        }

        .page-subtitle {
            font-size: 15px;
            color: var(--muted);
            font-weight: 300;
            line-height: 1.6;
        }

        .title-rule {
            width: 48px;
            height: 2px;
            background: var(--gold);
            margin: 20px auto 0;
            border-radius: 2px;
        }

        /* ── Cards Feed ── */
        .cards-feed {
            max-width: 760px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        /* ── Request Card ── */
        .request-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            transition: box-shadow 0.25s, transform 0.25s;
            animation: slideUp 0.4s ease-out both;
        }

        .request-card:nth-child(1) { animation-delay: 0.05s; }
        .request-card:nth-child(2) { animation-delay: 0.10s; }
        .request-card:nth-child(3) { animation-delay: 0.15s; }
        .request-card:nth-child(4) { animation-delay: 0.20s; }
        .request-card:nth-child(5) { animation-delay: 0.25s; }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .request-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-3px);
        }

        /* Card top accent bar */
        .card-accent-bar {
            height: 3px;
            background: linear-gradient(90deg, var(--accent) 0%, var(--gold) 100%);
        }

        /* Card Header */
        .card-header {
            padding: 28px 32px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
        }

        .card-header-left { flex: 1; }

        .card-topic {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 600;
            color: var(--text);
            line-height: 1.3;
            margin-bottom: 6px;
        }

        .card-sent-on {
            font-size: 12.5px;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .card-sent-on svg { opacity: 0.6; }

        /* Status Badge */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 13px;
            border-radius: 20px;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .status-pending  { background: var(--warn-lt);    color: var(--warn);    border: 1px solid #e8d5b0; }
        .status-accepted { background: var(--success-lt); color: var(--success); border: 1px solid #c4d9d3; }
        .status-rejected { background: var(--danger-lt);  color: var(--danger);  border: 1px solid #e0c4c4; }

        .status-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: currentColor;
            display: inline-block;
        }

        /* Card Body */
        .card-body { padding: 24px 32px; }

        /* Description */
        .description-block { margin-bottom: 24px; }

        .block-label {
            font-size: 10.5px;
            font-weight: 600;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .description-text {
            font-size: 14.5px;
            color: #444;
            line-height: 1.75;
            font-weight: 300;
        }

        /* Details Grid */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 24px;
        }

        .detail-tile {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            transition: border-color 0.2s, background 0.2s;
        }

        .detail-tile:hover {
            border-color: #ccc8c0;
            background: #f5f3ef;
        }

        .tile-icon {
            font-size: 18px;
            margin-bottom: 8px;
            display: block;
        }

        .tile-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 4px;
        }

        .tile-value {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            line-height: 1.3;
        }

        .mode-pill {
            display: inline-block;
            margin-top: 4px;
            padding: 2px 9px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 600;
        }

        .mode-online  { background: #e8f0fd; color: #2a52a0; }
        .mode-offline { background: #f5ede8; color: #7a3820; }
        .mode-hybrid  { background: #ede8f5; color: #4a2a7a; }

        /* Divider */
        .card-divider {
            height: 1px;
            background: var(--border);
            margin-bottom: 20px;
        }

        /* Action Buttons */
        .action-row {
            display: flex;
            gap: 10px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 11px 22px;
            border: none;
            border-radius: 10px;
            font-size: 13.5px;
            font-weight: 600;
            font-family: 'Lato', sans-serif;
            cursor: pointer;
            letter-spacing: 0.3px;
            transition: all 0.2s;
        }

        .btn-accept {
            background: var(--accent);
            color: #fff;
            box-shadow: 0 4px 14px rgba(44,74,62,0.25);
        }

        .btn-accept:hover {
            background: #223d32;
            box-shadow: 0 6px 20px rgba(44,74,62,0.35);
            transform: translateY(-1px);
        }

        .btn-reject {
            background: transparent;
            color: var(--danger);
            border: 1.5px solid #d4b4b4;
        }

        .btn-reject:hover {
            background: var(--danger-lt);
            border-color: var(--danger);
            transform: translateY(-1px);
        }

        .back-btn {
    position: fixed;
    top: 20px;
    left: 20px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Lato', sans-serif;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: all 0.2s;
    z-index: 1000;
}

.back-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: translateY(-1px);
}

        /* ── Empty State ── */
        .empty-state {
            max-width: 480px;
            margin: 0 auto;
            text-align: center;
            padding: 64px 32px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .empty-icon {
            width: 64px; height: 64px;
            background: var(--accent-lt);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px;
            font-size: 28px;
        }

        .empty-title {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 10px;
        }

        .empty-text {
            font-size: 14px;
            color: var(--muted);
            line-height: 1.65;
        }

        /* ── Responsive ── */
        @media (max-width: 640px) {
            body { padding: 32px 16px 60px; }
            .card-header { flex-direction: column; padding: 22px 22px 16px; }
            .card-body { padding: 18px 22px; }
            .details-grid { grid-template-columns: 1fr 1fr; }
            .action-row { flex-direction: column; }
            .btn { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

    <button class="back-btn" onclick="goBack()">
    ← Back
</button>

    <!-- Page Header -->
    <div class="page-header">
        <!-- <p class="page-eyebrow">Alumni Portal</p> -->
        <h1 class="page-title">Mentorship Session Requests</h1>
        <p class="page-subtitle">Review and respond to mentorship session requests sent by the administration.</p>
        <div class="title-rule"></div>
    </div>

    <!-- Cards Feed -->
    <div class="cards-feed">

        <% if(sessionReq && sessionReq.length > 0) { %>
            <% sessionReq.forEach((req) => { %>

            <div class="request-card">
                <div class="card-accent-bar"></div>

                <!-- Header -->
                <div class="card-header">
                    <div class="card-header-left">
                        <div class="card-topic"><%= req.Topic %></div>
                        <div class="card-sent-on">
                            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                            </svg>
                            Request sent on &nbsp;<strong><%= new Date(req.Created_On).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) %></strong>
                        </div>
                    </div>

                    <%
                        const status = (req.Status || 'pending').toLowerCase();
                        const statusClass = status === 'accepted' ? 'status-accepted'
                                          : status === 'rejected' ? 'status-rejected'
                                          : 'status-pending';
                        const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
                    %>
                    <span class="status-badge <%= statusClass %>">
                        <span class="status-dot"></span>
                        <%= statusLabel %>
                    </span>
                </div>

                <!-- Body -->
                <div class="card-body">

                    <!-- Description -->
                    <div class="description-block">
                        <div class="block-label">Session Description</div>
                        <div class="description-text"><%= req.Description %></div>
                    </div>

                    <!-- Detail Tiles -->
                    <div class="details-grid">
                        <div class="detail-tile">
                            <span class="tile-icon">📅</span>
                            <div class="tile-label">Scheduled Date</div>
                            <div class="tile-value">
                                <%= new Date(req.Session_Date).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) %>
                            </div>
                        </div>

                        <div class="detail-tile">
                            <span class="tile-icon">⏱</span>
                            <div class="tile-label">Duration</div>
                            <div class="tile-value"><%= req.Duration %></div>
                        </div>

                        <div class="detail-tile">
                            <span class="tile-icon">💻</span>
                            <div class="tile-label">Mode</div>
                            <div class="tile-value">
                                <%
                                    const mode = (req.Mode || '').toLowerCase();
                                    const modeClass = mode === 'online'  ? 'mode-online'
                                                    : mode === 'offline' ? 'mode-offline'
                                                    : 'mode-hybrid';
                                %>
                                <span class="mode-pill <%= modeClass %>"><%= req.Mode %></span>
                            </div>
                        </div>
                    </div>

                    <div class="card-divider"></div>

                    <!-- Actions -->
                    <div class="action-row">
                        <button class="btn btn-accept" onclick="handleAccept('<%= req.Session_ID %>')">
                            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                            Accept Request
                        </button>
                        <button class="btn btn-reject" onclick="handleReject('<%= req.Session_ID %>')">
                            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
                            Decline
                        </button>
                    </div>

                </div>
            </div>

            <% }) %>

        <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h3 class="empty-title">No Requests Yet</h3>
                <p class="empty-text">
                    You have no pending mentorship requests at the moment.<br>
                    To receive requests, enable the mentorship option in your profile settings.
                </p>
            </div>
        <% } %>

    </div>

    <script>
        function goBack() {
    window.history.back();
}

        function handleAccept(sessionId) {
            window.location.href = `/acceptMentorshipRequest/${sessionId}`;
        }

        function handleReject(sessionId) {
            window.location.href = `/rejectMentorshipRequest/${sessionId}`;
        }

        const alertMessage = "<%= alertMessage %>";
        if (alertMessage && alertMessage.trim() !== "") {
            alert(alertMessage);
        }
    </script>

</body>
</html>